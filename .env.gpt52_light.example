# GPT-5.2 diagnostic profile overlay (lightweight / timeout-avoidant)
# Use by copying to .env.gpt52_light and setting ENV_PROFILE=gpt52_light in .env

PERPLEXITY_COUNCIL_MODELS=openai/gpt-5.2
PERPLEXITY_PRESET_STRATEGY=advanced_only
PERPLEXITY_TIMEOUT_SECONDS=800
PERPLEXITY_MAX_STEPS=2
PERPLEXITY_REASONING_EFFORT=medium
MAX_SOURCES=5
PERPLEXITY_MAX_RESULTS_PER_QUERY=5
PERPLEXITY_STAGE1_SECOND_PASS_ENABLED=true
PERPLEXITY_STAGE1_SECOND_PASS_TIMEOUT_SECONDS=300
PERPLEXITY_STAGE1_SECOND_PASS_MAX_ATTEMPTS=2
PERPLEXITY_STAGE1_SECOND_PASS_REASONING_EFFORT=low
PERPLEXITY_STAGE1_OPENAI_BASE_MAX_SOURCES=5
PERPLEXITY_STAGE1_OPENAI_BASE_MAX_STEPS=2
PERPLEXITY_STAGE1_OPENAI_BASE_REASONING_EFFORT=medium

