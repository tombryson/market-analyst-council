# GPT-5.2 diagnostic profile overlay (reduced complexity)
# Use by copying to .env.gpt52_medium and setting ENV_PROFILE=gpt52_medium in .env

PERPLEXITY_COUNCIL_MODELS=openai/gpt-5.2
PERPLEXITY_PRESET_STRATEGY=advanced_only
PERPLEXITY_TIMEOUT_SECONDS=1000
PERPLEXITY_MAX_STEPS=3
PERPLEXITY_REASONING_EFFORT=medium
MAX_SOURCES=6
PERPLEXITY_MAX_RESULTS_PER_QUERY=6
PERPLEXITY_STAGE1_SECOND_PASS_ENABLED=true
PERPLEXITY_STAGE1_SECOND_PASS_TIMEOUT_SECONDS=240
PERPLEXITY_STAGE1_SECOND_PASS_MAX_ATTEMPTS=2
PERPLEXITY_STAGE1_SECOND_PASS_REASONING_EFFORT=medium

