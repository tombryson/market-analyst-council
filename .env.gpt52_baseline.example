# GPT-5.2 diagnostic profile overlay
# Use by copying to .env.gpt52_baseline and setting ENV_PROFILE=gpt52_baseline in .env

PERPLEXITY_COUNCIL_MODELS=openai/gpt-5.2
PERPLEXITY_PRESET_STRATEGY=adaptive
PERPLEXITY_TIMEOUT_SECONDS=1000
PERPLEXITY_MAX_STEPS=4
PERPLEXITY_REASONING_EFFORT=high
MAX_SOURCES=7
PERPLEXITY_MAX_RESULTS_PER_QUERY=7
PERPLEXITY_STAGE1_SECOND_PASS_ENABLED=true
PERPLEXITY_STAGE1_SECOND_PASS_TIMEOUT_SECONDS=180
PERPLEXITY_STAGE1_SECOND_PASS_MAX_ATTEMPTS=2
PERPLEXITY_STAGE1_SECOND_PASS_REASONING_EFFORT=high

