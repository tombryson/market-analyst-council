# Configuration source of truth:
# - Runtime/test scripts read these values directly.
# - Env precedence can be controlled explicitly:
#   ENV_PRECEDENCE=env  -> shell/process env overrides file values (default)
#   ENV_PRECEDENCE=file -> .env/.env.<profile>/.env.local override shell env
# - Optional profile overlays:
#   ENV_PROFILE=dev loads .env.dev after .env
#   ENV_PROFILE=staging loads .env.staging after .env
#   ENV_PROFILE=prod loads .env.prod after .env
# - Optional .env.local is loaded last for machine-local overrides.
ENV_PRECEDENCE=env
ENV_PROFILE=

# Required for council model calls
OPENROUTER_API_KEY=sk-or-v1-...

# Optional legacy search provider
TAVILY_API_KEY=tvly-...

# xAI API (supplementary sector macro brief for Stage 1 injection)
XAI_API_KEY=xai-...
XAI_API_URL=https://api.x.ai/v1/responses

# Optional alternate document parser backend
LLAMAPARSE_API_KEY=llx-...
LLAMAPARSE_API_URL=https://api.cloud.llamaindex.ai/api/v2/parse
LLAMAPARSE_UPLOAD_URL=https://api.cloud.llamaindex.ai/api/v2/parse/upload
LLAMAPARSE_TIER=agentic
LLAMAPARSE_VERSION=latest
LLAMAPARSE_COST_OPTIMIZER_ENABLED=true
LLAMAPARSE_TIMEOUT_SECONDS=240
LLAMAPARSE_POLL_INTERVAL_SECONDS=2

# Local free parser option
LITEPARSE_OCR_ENABLED=false
LITEPARSE_TIMEOUT_SECONDS=240

# Research provider routing
ENABLE_RESEARCH_SERVICE=false
PROGRESS_LOGGING=true
SYSTEM_ENABLED=true
SYSTEM_SHUTDOWN_REASON=System temporarily disabled for audit and diagnostics.
# When SYSTEM_ENABLED=false, allow dedicated diagnostic scripts to run.
SYSTEM_ALLOW_DIAGNOSTICS_WHEN_DISABLED=true
RESEARCH_PROVIDER=tavily
# Options: tavily | perplexity
RESEARCH_DEPTH=basic
MAX_SOURCES=20
# Deterministic ASX ingestion lane (latest announcements -> decode -> Stage 1 injection)
ASX_DETERMINISTIC_ANNOUNCEMENTS_ENABLED=true
ASX_DETERMINISTIC_TARGET_ANNOUNCEMENTS=10
ASX_DETERMINISTIC_LOOKBACK_YEARS=2
ASX_DETERMINISTIC_PRICE_SENSITIVE_ONLY=true
ASX_DETERMINISTIC_INCLUDE_NON_SENSITIVE_FILL=false
ASX_DETERMINISTIC_MAX_DECODE=10
ASX_DETERMINISTIC_FETCH_TIMEOUT_SECONDS=20
ENABLE_MARKET_FACTS_PREPASS=true
MARKET_FACTS_TIMEOUT_SECONDS=12
ENABLE_COMPANY_TYPE_API_DETECTION=true
# tavily | perplexity
COMPANY_TYPE_DETECTION_PROVIDER=tavily
COMPANY_TYPE_DETECTION_TIMEOUT_SECONDS=20
COMPANY_TYPE_DETECTION_MAX_RESULTS=5
COMPANY_TYPE_DETECTION_MIN_CONFIDENCE=0.55
COMPANY_TYPE_DETECTION_PERPLEXITY_MODEL=sonar-pro
COMPANY_TYPE_DETECTION_MAX_OUTPUT_TOKENS=320

# OpenRouter council models (used for local Stage 1 and all Stage 2 judging)
COUNCIL_MODELS=minimax/minimax-m2.7,x-ai/grok-4.20,qwen/qwen3.6-plus:free,z-ai/glm-5-turbo,google/gemma-4-26b-a4b-it,moonshotai/kimi-k2.5
CHAIRMAN_MODEL=google/gemini-3.1-pro-preview
# Stage 3 chairman call budgets (explicit; avoid hidden provider defaults)
CHAIRMAN_TIMEOUT_SECONDS=300
CHAIRMAN_MAX_OUTPUT_TOKENS=0
# text_xml (recommended) | json
CHAIRMAN_OUTPUT_STYLE=text_xml
# Secondary JSON normalizer for chairman output
CHAIRMAN_JSONIFIER_MODEL=google/gemini-3.1-flash-lite-preview
CHAIRMAN_JSONIFY_ALWAYS=true
CHAIRMAN_JSONIFIER_TIMEOUT_SECONDS=180
CHAIRMAN_JSONIFIER_MAX_OUTPUT_TOKENS=12000
# Human-readable Stage 3 memo generated from chairman output + Stage 1 model table
STAGE3_ANALYST_MEMO_ENABLED=true
STAGE3_ANALYST_MEMO_MODEL=google/gemini-3.1-flash-lite-preview
STAGE3_ANALYST_MEMO_TIMEOUT_SECONDS=180
STAGE3_ANALYST_MEMO_MAX_OUTPUT_TOKENS=5000
# Stage 1 per-model response parser used for compact reference extraction
STAGE1_REFERENCE_PARSER_MODEL=google/gemini-3.1-flash-lite-preview

# Council execution mode
# local | perplexity_emulated
COUNCIL_EXECUTION_MODE=local

# Perplexity research settings
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_API_URL=https://api.perplexity.ai/v1/responses
# Recommended for SEC access (avoid 403 on sec.gov endpoints):
# include app/org name + contact email.
SEC_API_IDENTITY=llm-council/1.0 (you@yourdomain.com)
PERPLEXITY_MODEL=openai/gpt-5.4
# single | adaptive | deep_only | advanced_only
PERPLEXITY_PRESET_STRATEGY=adaptive
PERPLEXITY_PRESET=deep-research
PERPLEXITY_PRESET_DEEP=deep-research
PERPLEXITY_PRESET_ADVANCED=advanced-deep-research
PERPLEXITY_STREAM_ENABLED=true
# standard | pro (pro is Sonar-oriented and requires streaming)
PERPLEXITY_SEARCH_MODE=standard
# if filters payload is rejected, retry once with legacy tool keys
PERPLEXITY_USE_LEGACY_TOOL_FILTER_FALLBACK=true
PERPLEXITY_TIMEOUT_SECONDS=180
PERPLEXITY_MAX_STEPS=10
# 0 = omit max_output_tokens in payload (provider-side cap only)
PERPLEXITY_MAX_OUTPUT_TOKENS=0
PERPLEXITY_REASONING_EFFORT=low
PERPLEXITY_ENABLE_WEB_SEARCH_TOOL=true
PERPLEXITY_ENABLE_FETCH_URL_TOOL=true
PERPLEXITY_MAX_RESULTS_PER_QUERY=20
PERPLEXITY_MAX_TOKENS_PER_PAGE=1024
PERPLEXITY_ALLOWED_DOMAINS=
PERPLEXITY_BLOCKED_DOMAINS=
PERPLEXITY_SEARCH_AFTER_DATE_FILTER=
PERPLEXITY_SEARCH_BEFORE_DATE_FILTER=
PERPLEXITY_STAGE1_EXECUTION_MODE=staggered
PERPLEXITY_STAGE1_STAGGER_SECONDS=2.0
# 0 = no truncation of attachment context injected into Stage 1 query
PERPLEXITY_STAGE1_ATTACHMENT_CONTEXT_MAX_CHARS=0
PERPLEXITY_STAGE1_MULTI_WAVE_ENABLED=true
PERPLEXITY_STAGE1_MULTI_WAVE_MAX_WAVES=3
PERPLEXITY_STAGE1_MULTI_WAVE_GAP_QUERY_LIMIT=3
PERPLEXITY_STAGE1_MULTI_WAVE_MIN_NEW_PRIMARY_SOURCES=1
PERPLEXITY_STAGE1_SONAR_MULTISTEP_REQUIRED=true
# Perplexity model-ID preflight: probes configured Perplexity pool models and
# removes definitively unsupported IDs before Stage 1 retrieval starts.
PERPLEXITY_STAGE1_MODEL_PREFLIGHT_ENABLED=true
PERPLEXITY_STAGE1_MODEL_PREFLIGHT_TIMEOUT_SECONDS=30
# fail_open=true keeps transiently failing probe models; unsupported models are still removed.
PERPLEXITY_STAGE1_MODEL_PREFLIGHT_FAIL_OPEN=true
DETERMINISTIC_FINANCE_LANE_ENABLED=true
# Total attempts per model (first attempt + retries)
PERPLEXITY_STAGE1_MAX_ATTEMPTS=3
# Legacy retries setting (only used if MAX_ATTEMPTS <= 0)
PERPLEXITY_STAGE1_MAX_RETRIES=3
PERPLEXITY_STAGE1_RETRY_BACKOFF_SECONDS=5
# Disable strict template-compliance retry by default (logs warning only).
PERPLEXITY_STAGE1_TEMPLATE_RETRY_ENABLED=false
# Two-pass Stage 1: pass 1 retrieves/decodes, pass 2 performs model analysis on decoded evidence.
PERPLEXITY_STAGE1_SECOND_PASS_ENABLED=true
PERPLEXITY_STAGE1_SECOND_PASS_TIMEOUT_SECONDS=300
PERPLEXITY_STAGE1_SECOND_PASS_MAX_ATTEMPTS=2
PERPLEXITY_STAGE1_SECOND_PASS_RETRY_BACKOFF_SECONDS=4
PERPLEXITY_STAGE1_SECOND_PASS_MAX_SOURCES=20
PERPLEXITY_STAGE1_SECOND_PASS_MAX_CHARS_PER_SOURCE=1200
PERPLEXITY_STAGE1_SECOND_PASS_MAX_OUTPUT_TOKENS=0
PERPLEXITY_STAGE1_SECOND_PASS_REASONING_EFFORT=high
PERPLEXITY_STAGE1_SECOND_PASS_APPENDIX_MAX_SOURCES=5
# Adaptive prompt compression for Stage 1 second-pass injections.
PERPLEXITY_STAGE1_SECOND_PASS_PROMPT_COMPRESSION_ENABLED=true
PERPLEXITY_STAGE1_SECOND_PASS_PROMPT_TARGET_CHARS=32000
# Per-source deterministic key-point extraction used for Stage 1 evidence injection.
PERPLEXITY_STAGE1_SECOND_PASS_DOC_KEYPOINTS_MAX_PER_SOURCE=8
PERPLEXITY_STAGE1_SECOND_PASS_DOC_KEYPOINTS_MAX_WORDS_PER_SOURCE=500
PERPLEXITY_STAGE1_SECOND_PASS_DOC_KEYPOINTS_MAX_FACT_CHARS=420
STAGE1_CASHFLOW_DETECTION_MAX_SOURCES=24
STAGE1_CASHFLOW_CLASSIFIER_ENABLED=true
STAGE1_CASHFLOW_CLASSIFIER_MODEL=google/gemini-3-flash-preview
STAGE1_CASHFLOW_CLASSIFIER_TIMEOUT_SECONDS=35
STAGE1_CASHFLOW_CLASSIFIER_MAX_OUTPUT_TOKENS=260
STAGE1_CASHFLOW_CLASSIFIER_REASONING_EFFORT=low
STAGE1_CASHFLOW_CLASSIFIER_MIN_CONFIDENCE_PCT=70
# Supplementary sector-macro/news lane injected in addition to core source rows.
PERPLEXITY_STAGE1_SUPPLEMENTARY_NEWS_ENABLED=true
PERPLEXITY_STAGE1_SUPPLEMENTARY_NEWS_MAX_SOURCES=3
PERPLEXITY_STAGE1_SUPPLEMENTARY_NEWS_RETRIEVAL_MAX_SOURCES=8
PERPLEXITY_STAGE1_SUPPLEMENTARY_NEWS_MAX_RECENCY_DAYS=180
# xAI generation settings for supplementary macro brief
STAGE1_SUPPLEMENTARY_XAI_MODEL=grok-4-1-fast-reasoning
STAGE1_SUPPLEMENTARY_XAI_TIMEOUT_SECONDS=90
STAGE1_SUPPLEMENTARY_XAI_MAX_TOKENS=700
STAGE1_SUPPLEMENTARY_XAI_TEMPERATURE=0.2
STAGE1_SUPPLEMENTARY_XAI_MAX_TOOL_ITERATIONS=6
PERPLEXITY_STAGE1_TIMELINE_GUARD_ENABLED=true
PERPLEXITY_STAGE1_TIMELINE_GUARD_HARD_FAIL=true
PERPLEXITY_STAGE1_TIMELINE_DIGEST_MAX_ITEMS=8
PERPLEXITY_STAGE1_FACT_DIGEST_V2_ENABLED=true
PERPLEXITY_STAGE1_FACT_DIGEST_V2_MAX_FACTS_PER_SECTION=6
PERPLEXITY_STAGE1_FACT_DIGEST_V2_MAX_SUMMARY_BULLETS=12
PERPLEXITY_STAGE1_FACT_DIGEST_V2_MAX_NARRATIVE_WORDS=500
PERPLEXITY_STAGE1_SECOND_PASS_CITATION_GATE_ENABLED=true
PERPLEXITY_STAGE1_SECOND_PASS_CITATION_MIN_COUNT=2
PERPLEXITY_STAGE1_SECOND_PASS_CITATION_MAX_UNCITED_NUMERIC_LINES=2
PERPLEXITY_STAGE1_SECOND_PASS_COMPLIANCE_MIN_SCORE=0.75
PERPLEXITY_STAGE1_SECOND_PASS_COMPLIANCE_MIN_RUBRIC_COVERAGE_PCT=0.60
PERPLEXITY_STAGE1_SECOND_PASS_COMPLIANCE_MIN_NUMERIC_CITATION_PCT=0.60
PERPLEXITY_STAGE1_SECOND_PASS_COMPLIANCE_CATASTROPHIC_SCORE=0.35
# Retrieve/decode once, then reuse evidence for all model analyses
PERPLEXITY_STAGE1_SHARED_RETRIEVAL_ENABLED=true
# Optional explicit retrieval model (must be one of PERPLEXITY_COUNCIL_MODELS)
PERPLEXITY_STAGE1_SHARED_RETRIEVAL_MODEL=
# OpenAI pass-1 guardrails to reduce deep-research timeout risk
PERPLEXITY_STAGE1_OPENAI_BASE_GUARDRAILS_ENABLED=true
PERPLEXITY_STAGE1_OPENAI_BASE_MAX_SOURCES=6
PERPLEXITY_STAGE1_OPENAI_BASE_MAX_STEPS=3
PERPLEXITY_STAGE1_OPENAI_BASE_REASONING_EFFORT=medium
PERPLEXITY_STAGE1_OPENAI_BASE_DOWNGRADE_HIGH_REASONING=false
# Optional Stage 2.5 peer-revision pass.
# If a revision JSON is malformed/invalid, prior model output is kept unchanged.
STAGE2_REVISION_PASS_ENABLED=true
STAGE2_REVISION_PASS_TIMEOUT_SECONDS=120
STAGE2_REVISION_PASS_MAX_OUTPUT_TOKENS=1200
ENABLE_SOURCE_DECODING=true
SOURCE_DECODING_MAX_PER_MODEL=20
SOURCE_DECODING_MAX_CHARS=3500
SOURCE_DECODING_TIMEOUT_SECONDS=20

# Models for emulated Perplexity Stage 1 (comma-separated)
# Perplexity model IDs differ from OpenRouter IDs for some providers.
PERPLEXITY_COUNCIL_MODELS=openai/gpt-5.4,google/gemini-3.1-pro-preview,anthropic/claude-sonnet-4-6
# Optional mixed-provider Stage 1 fanout:
# - Retrieval/decode runs once via Perplexity pool.
# - Analysis fanout routes Perplexity pool models via Perplexity API and
#   OpenRouter pool models via OpenRouter API with the same injected evidence bundle.
PERPLEXITY_STAGE1_MIXED_MODE_ENABLED=false
# Optional explicit OpenRouter analysis pool (comma-separated).
# If empty and mixed mode is enabled, falls back to COUNCIL_MODELS.
PERPLEXITY_STAGE1_OPENROUTER_MODELS=x-ai/grok-4.20,minimax/minimax-m2.7,qwen/qwen3.6-plus:free,z-ai/glm-5-turbo,google/gemma-4-26b-a4b-it,moonshotai/kimi-k2.5

# Optional web-search domain/date filters examples:
# PERPLEXITY_ALLOWED_DOMAINS=asx.com.au,sec.gov
# PERPLEXITY_BLOCKED_DOMAINS=reddit.com
# PERPLEXITY_SEARCH_AFTER_DATE_FILTER=2025-01-01
# PERPLEXITY_SEARCH_BEFORE_DATE_FILTER=2026-12-31
